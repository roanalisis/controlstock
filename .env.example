# Copia este archivo como .env y completa los valores para desarrollo local.
# En producción, definir estas variables en Netlify UI (no en este archivo).

# URL base del backend (sin trailing slash).
# Dejar vacío en local: Vite redirige /api → http://localhost:8000 vía proxy.
# En Netlify setear: VITE_API_URL=https://controlstock-api.onrender.com
VITE_API_URL=
